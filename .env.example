# ─────────────────────────────────────────────────────────────
# reel-managment configuration
# Copy to .env.local and fill in. Nothing here is committed.
# ─────────────────────────────────────────────────────────────

# Data source: "mock" (fake data, no Instagram needed) or "graph" (live Instagram Graph API)
DATA_SOURCE=mock

# ── Instagram Graph API (only needed when DATA_SOURCE=graph) ──
# Get these from https://developers.facebook.com → your App.
# The account MUST be an Instagram Business or Creator account linked to a Facebook Page.
IG_GRAPH_VERSION=v21.0
# Long-lived access token with: instagram_basic, instagram_manage_comments,
# instagram_manage_messages, pages_manage_metadata, pages_read_engagement
IG_ACCESS_TOKEN=
# Your Instagram Business account id (the IGSID / ig-user-id the token is for). Leave blank to auto-detect via /me.
IG_USER_ID=

# ── App security ──
# Random secret required to trigger the scheduled run endpoint (/api/cron).
# Generate with: openssl rand -hex 32
CRON_SECRET=change-me

# Shared secret the Chrome extension uses to authenticate to this backend.
EXTENSION_TOKEN=change-me-too

# ── Behaviour ──
# Predefined message sent to commenters you haven't replied to. {username} is substituted.
DEFAULT_DM_MESSAGE=Hey {username}! Thanks so much for commenting 🙏 Check your DMs for the link!

# Max DMs to send in a single run (safety rate limit).
MAX_DMS_PER_RUN=20

# Seconds to wait between each DM in a run (safety throttle).
DM_DELAY_SECONDS=8
